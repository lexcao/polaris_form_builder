<s-box
  background="strong"
  borderRadius="large"
  padding="base"
>
  <s-stack gap="base">
    <h3>Preview</h3>

    <%= polaris_form_with(model: Preview.new, url: preview_component_path(@component)) do |form| %>
      <s-stack gap="base">
        <%= render inline: code, locals: { form: form } %>
        <%= form.submit "Try it" %>
      </s-stack>
    <% end %>
  </s-stack>
</s-box>

#!/usr/bin/env ruby
# frozen_string_literal: true

require "rubygems"
require "bundler/setup"

require "active_support/continuous_integration"

CI = ActiveSupport::ContinuousIntegration

CI.run do
  step "Setup", "bin/setup"

  step "Lint: RuboCop", "bin/rubocop -f github"

  step "Tests: Unit", "bundle exec rake test_unit"

  step "Install: Dummy", "cd test/dummy && env -u BUNDLE_GEMFILE -u RUBYGEMS_GEMDEPS bundle install"
  step "Setup: Dummy", "cd test/dummy && env -u BUNDLE_GEMFILE -u RUBYGEMS_GEMDEPS bin/rails db:prepare"
  step "Tests: Dummy integration", "cd test/dummy && env -u BUNDLE_GEMFILE -u RUBYGEMS_GEMDEPS bin/rails test"

  step "Install: Playground", "cd app/playground && env -u BUNDLE_GEMFILE -u RUBYGEMS_GEMDEPS bundle install"
  step "Setup: Playground", "cd app/playground && env -u BUNDLE_GEMFILE -u RUBYGEMS_GEMDEPS bin/rails db:prepare"
  step "Tests: Playground E2E", "cd app/playground && env -u BUNDLE_GEMFILE -u RUBYGEMS_GEMDEPS bin/rails test"
  step "Tests: Playground seeds", "cd app/playground && env -u BUNDLE_GEMFILE -u RUBYGEMS_GEMDEPS env RAILS_ENV=test bin/rails db:seed:replant"
end

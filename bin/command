#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "./dev/command"

if __FILE__ == $PROGRAM_NAME
  if ARGV.empty?
    puts "Usage: #{$PROGRAM_NAME} <sync>"
    exit 1
  end

  command = ARGV[0]

  case command
  when "sync", "1"
    Command::Sync.new.run
  else
    puts "Unknown command: #{command}"
  end
end
